#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Consenti di saltare i check con SKIP_PRE_PUSH=1 (solo se serve davvero)
[ "$SKIP_PRE_PUSH" = "1" ] && exit 0

echo "Pre-push: lint..."
npm run lint || exit 1

echo "Pre-push: test (headless)..."
npm run test:ci || exit 1

echo "Pre-push: build (prod)..."
npm run build:ci || exit 1
